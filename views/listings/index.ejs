<% layout("/layouts/boilerplate") %>

<style>
  .filter-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0;
    margin-bottom: 1rem;
    gap: 2rem;
  }
  #filters {
    display: flex;
    overflow-x: auto;
    gap: 2rem;
    flex: 1;
  }
  #filters::-webkit-scrollbar {
    height: 0;
  }
</style>

<div class="filter-section">
  <div id="filters">
    <div class="filter">
      <lord-icon src="https://cdn.lordicon.com/fkaukecx.json" trigger="hover" colors="primary:#222222" style="width:24px;height:24px"></lord-icon>
      <span>Trending</span>
    </div>
    <div class="filter">
      <i class="fa-solid fa-bed"></i>
      <span>Rooms</span>
    </div>
    <div class="filter">
      <lord-icon src="https://cdn.lordicon.com/wmwqvixz.json" trigger="hover" colors="primary:#222222" style="width:24px;height:24px"></lord-icon>
      <span>Iconic Cities</span>
    </div>
    <div class="filter">
      <lord-icon src="https://cdn.lordicon.com/iltqorsz.json" trigger="hover" colors="primary:#222222" style="width:24px;height:24px"></lord-icon>
      <span>Mountains</span>
    </div>
    <div class="filter">
      <lord-icon src="https://cdn.lordicon.com/fpmskzsv.json" trigger="hover" colors="primary:#222222" style="width:24px;height:24px"></lord-icon>
      <span>Castles</span>
    </div>
    <div class="filter">
      <lord-icon src="https://cdn.lordicon.com/jfhbogmw.json" trigger="hover" colors="primary:#222222" style="width:24px;height:24px"></lord-icon>
      <span>Amazing Pools</span>
    </div>
    <div class="filter">
      <lord-icon src="https://cdn.lordicon.com/piwupaqb.json" trigger="hover" colors="primary:#222222" style="width:24px;height:24px"></lord-icon>
      <span>Camping</span>
    </div>
    <div class="filter">
      <lord-icon src="https://cdn.lordicon.com/qvyppzqz.json" trigger="hover" colors="primary:#222222" style="width:24px;height:24px"></lord-icon>
      <span>Farms</span>
    </div>
    <div class="filter">
      <i class="fa-solid fa-snowflake"></i>
      <span>Arctic</span>
    </div>
    <div class="filter">
      <i class="fa-solid fa-igloo"></i>
      <span>Domes</span>
    </div>
    <div class="filter">
      <lord-icon src="https://cdn.lordicon.com/vdjwmfqs.json" trigger="hover" colors="primary:#222222" style="width:24px;height:24px"></lord-icon>
      <span>Boats</span>
    </div>
  </div>

  <div class="tax-toggle">
    <span>Display total before taxes</span>
    <div class="form-check form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
    </div>
  </div>
</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

        <!-- <form method="get" action="/listings/new">
        <button>create new listing</button>
    </form> -->
        <% for(let listing of alllisting){ %>
            <a href="/listings/<%= listing._id %>" class="listing-link mt-3">
                <div class="card  listing-card">
                    <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/800x600?text=No+Image' %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <B>
                                <%=listing.title %>
                            </B>
                            <br>
                            <span class="listing-price">&#8377 <%= listing.price.toLocaleString("en-IN")%></span>
                            <span class="listing-price-with-tax" style="display: none;">&#8377 <%= (listing.price * 1.18).toLocaleString("en-IN", {maximumFractionDigits: 0})%></span>
                            / night
                            <i class="tax-info">+18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
            <% } %>

    </div>

<script>
  let taxSwitch = document.getElementById("flexSwitchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfoElements = document.querySelectorAll(".tax-info");
    let priceElements = document.querySelectorAll(".listing-price");
    let priceWithTaxElements = document.querySelectorAll(".listing-price-with-tax");
    
    if (taxSwitch.checked) {
      // Show price with tax included
      taxInfoElements.forEach((el) => el.style.display = "none");
      priceElements.forEach((el) => el.style.display = "none");
      priceWithTaxElements.forEach((el) => el.style.display = "inline");
    } else {
      // Show original price with GST label
      taxInfoElements.forEach((el) => el.style.display = "inline");
      priceElements.forEach((el) => el.style.display = "inline");
      priceWithTaxElements.forEach((el) => el.style.display = "none");
    }
  });
</script>