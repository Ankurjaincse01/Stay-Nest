<% layout("/layouts/boilerplate") %>

<div class="container show-container">
    <div class="row">
        <div class="col-lg-8 col-md-10 mx-auto">
            <!-- Title Section -->
            <div class="show-header">
                <h2 class="show-title"><%= listing.title %></h2>
            </div>

            <!-- Image Section -->
            <div class="show-image-wrapper">
                <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/800x600?text=No+Image' %>" 
                     class="show-img" 
                     alt="listing_image">
            </div>

            <!-- Info Section -->
            <div class="show-info">
                <p class="show-owner">Hosted by <span><%= listing.owner ? listing.owner.username : 'Airbnb Host' %></span></p>
                <p class="show-description"><%= listing.description %></p>
                <div class="show-details">
                    <p class="show-price">&#8377 <%= listing.price.toLocaleString("en-IN")%> <span>/ night</span></p>
                    <p class="show-location"><i class="fa-solid fa-location-dot"></i> <%= listing.location%>, <%= listing.country%></p>
                </div>
            </div>

            <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
            <!-- Action Buttons -->
            <div class="show-actions">
                <a href="/listings/<%=listing._id %>/edit" class="btn btn-dark">Edit</a>
                <form method="post" action="/listings/<%= listing._id%>?_method=delete" class="d-inline">
                    <button class="btn btn-outline-dark">Delete</button>
                </form>
            </div>
            <% } %>

            <!-- Map Section -->
            <div class="show-map-section">
                <h4>Where you'll be</h4>
                <div id="map"></div>
            </div>

            <script>
              // @ts-nocheck
              const listing = <%- JSON.stringify(listing) %>
            </script>

            <% if(currUser) { %>
            <!-- Review Form -->
            <div class="show-review-form">
                <hr>
                <h4>Leave a Review</h4>
                <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                    <div class="mb-3">
                        <div class="star-rating">
                            <input type="radio" id="star5" name="review[rating]" value="5" />
                            <label for="star5" title="5 stars">★</label>
                            <input type="radio" id="star4" name="review[rating]" value="4" />
                            <label for="star4" title="4 stars">★</label>
                            <input type="radio" id="star3" name="review[rating]" value="3" />
                            <label for="star3" title="3 stars">★</label>
                            <input type="radio" id="star2" name="review[rating]" value="2" />
                            <label for="star2" title="2 stars">★</label>
                            <input type="radio" id="star1" name="review[rating]" value="1" />
                            <label for="star1" title="1 star">★</label>
                        </div>
                    </div>
                    <div class="mb-3 mt-3"> 
                        <label for="comment" class="form-label">Comments</label>
                        <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control" required></textarea>
                        <div class="invalid-feedback">Please add some comments for review</div>
                    </div>
                    <button class="btn btn-dark">Submit Review</button>
                </form>
            </div>
            <% } %>

            <% if(listing.reviews && listing.reviews.length > 0) { %>
            <!-- All Reviews -->
            <div class="show-reviews">
                <hr>
                <h4>All Reviews</h4>
                <div class="row">
                    <% for(let review of listing.reviews) { %>
                    <div class="col-md-6 mb-3">
                        <div class="review-card">
                            <div class="review-header">
                                <h5>@<%= review.author.username %></h5>
                                <p class="review-stars">
                                    <% for(let i = 1; i <= 5; i++) { %>
                                        <span class="<%= i <= review.rating ? 'star-filled' : 'star-empty' %>">★</span>
                                    <% } %>
                                </p>
                            </div>
                            <p class="review-comment"><%= review.comment %></p>
                            <% if(currUser && review.author._id.equals(currUser._id)) { %>
                            <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="d-inline">
                                <button class="btn btn-sm btn-outline-dark">Delete</button>
                            </form>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</div>